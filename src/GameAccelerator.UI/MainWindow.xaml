<Window x:Class="GameAccelerator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GameAccelerator.UI.ViewModels"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="游戏加速器" Height="550" Width="860"
        MinHeight="500" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation -->
        <Grid Grid.Column="0" Background="#2B2B2B">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- App Title -->
            <TextBlock Grid.Row="0" Text="游戏加速器" Foreground="White"
                       FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Nav Items -->
            <ListBox Grid.Row="1" x:Name="NavListBox"
                     Background="Transparent" BorderThickness="0"
                     SelectionChanged="NavListBox_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="#AAAAAA"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="20,12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3B3B3B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBoxItem Tag="Dashboard">📊 仪表盘</ListBoxItem>
                <ListBoxItem Tag="Services">🔧 服务管理</ListBoxItem>
                <ListBoxItem Tag="Traffic">📈 流量监控</ListBoxItem>
                <ListBoxItem Tag="Settings">⚙ 设置</ListBoxItem>
            </ListBox>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="0">
            <!-- Dashboard View -->
            <Grid x:Name="DashboardPanel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Status Card -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="24,16" Margin="16,16,16,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse Grid.Column="0" Width="16" Height="16"
                                 x:Name="StatusDot" Fill="#D13438"/>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="游戏加速器 | SNI代理模式" FontSize="12" Foreground="#888"/>
                        </StackPanel>

                        <Button Grid.Column="2" Height="40" Width="140"
                                Command="{Binding ToggleAccelerationCommand}"
                                FontSize="15" FontWeight="Bold" Foreground="White"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#0078D4"/>
                                    <Setter Property="Content" Value="一键加速"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Background" Value="#D13438"/>
                                            <Setter Property="Content" Value="停止加速"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Speed Stats -->
                <Grid Grid.Row="1" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="⬇ 下载速度" FontSize="12" Foreground="#888"/>
                            <TextBlock Text="{Binding DownloadSpeed}" FontSize="24" FontWeight="Bold"
                                       Foreground="#0078D4" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="16" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="⬆ 上传速度" FontSize="12" Foreground="#888"/>
                            <TextBlock Text="{Binding UploadSpeed}" FontSize="24" FontWeight="Bold"
                                       Foreground="#D13438" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="16" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="📊 总流量" FontSize="12" Foreground="#888"/>
                            <TextBlock FontSize="24" FontWeight="Bold" Margin="0,4,0,0">
                                <Run Text="{Binding TotalDownloaded}" Foreground="#0078D4"/> /
                                <Run Text="{Binding TotalUploaded}" Foreground="#D13438"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Service Status -->
                <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20,12" Margin="16,12,16,8">
                    <StackPanel>
                        <TextBlock Text="服务状态" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="#107C10" VerticalAlignment="Center"/>
                                <TextBlock Text=" Steam 加速" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="#107C10" VerticalAlignment="Center"/>
                                <TextBlock Text=" GitHub 加速" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="#107C10" VerticalAlignment="Center"/>
                                <TextBlock Text=" 游戏加速" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Service List View -->
            <Grid x:Name="ServiceListPanel" Visibility="Collapsed">
                <ScrollViewer Margin="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="服务管理" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- Steam Service Card -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Steam 加速" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="商店、社区、工坊、下载" FontSize="12" Foreground="#888"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" x:Name="SteamToggle"
                                          IsChecked="{Binding SteamEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- GitHub Service Card -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="GitHub 加速" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="网页、克隆、下载、Release" FontSize="12" Foreground="#888"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" x:Name="GitHubToggle"
                                          IsChecked="{Binding GithubEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Games Service Card -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="游戏加速" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="SOCKS5 代理 (127.0.0.1:10808)" FontSize="12" Foreground="#888"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" x:Name="GamesToggle"
                                          IsChecked="{Binding GamesEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- System Proxy -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="系统代理" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="自动设置 Windows 系统代理" FontSize="12" Foreground="#888"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding SystemProxyEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- TCP Optimization -->
                        <Border Background="White" CornerRadius="8" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="TCP 优化" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="启用 CTCP 拥塞控制，优化高延迟连接" FontSize="12" Foreground="#888"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding TcpOptimizationEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Traffic View -->
            <Grid x:Name="TrafficPanel" Visibility="Collapsed" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="流量监控" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

                <lvc:CartesianChart Grid.Row="1" Series="{Binding Series}"
                                    XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                    Background="White" Margin="0,0,0,12"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="总下载" FontSize="11" Foreground="#888"/>
                            <TextBlock Text="{Binding TotalDownloaded}" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="12" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="总上传" FontSize="11" Foreground="#888"/>
                            <TextBlock Text="{Binding TotalUploaded}" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="12" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="峰值下载" FontSize="11" Foreground="#888"/>
                            <TextBlock Text="{Binding PeakDownload}" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="峰值上传" FontSize="11" Foreground="#888"/>
                            <TextBlock Text="{Binding PeakUpload}" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Settings View -->
            <Grid x:Name="SettingsPanel" Visibility="Collapsed" Margin="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- Port Settings -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="代理端口" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="SNI 代理端口" FontSize="12" Foreground="#888"/>
                                        <TextBox Text="{Binding SniProxyPort}" Margin="0,4,0,0"
                                                 Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="SOCKS5 代理端口" FontSize="12" Foreground="#888"/>
                                        <TextBox Text="{Binding Socks5Port}" Margin="0,4,0,0"
                                                 Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Behavior Settings -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="行为设置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <CheckBox Content="开机自动启动" IsChecked="{Binding AutoStart}"
                                          Margin="0,0,0,8"/>
                                <CheckBox Content="启动时最小化到托盘" IsChecked="{Binding MinimizeToTray}"/>
                            </StackPanel>
                        </Border>

                        <!-- Save Button -->
                        <Button Content="保存设置" Command="{Binding SaveSettingsCommand}"
                                Height="40" Width="120"
                                Background="#0078D4" Foreground="White"
                                BorderThickness="0" FontSize="14" FontWeight="SemiBold"
                                HorizontalAlignment="Right" Cursor="Hand"/>

                        <TextBlock Text="{Binding StatusMessage}" Foreground="#107C10"
                                   FontSize="12" HorizontalAlignment="Right" Margin="0,8,12,0"/>

                        <!-- About Section -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="关于" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="游戏加速器 v1.0" FontSize="13"/>
                                <TextBlock Text="基于 SNI 代理 + DNS 优化的本地加速工具" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                                <TextBlock Text="无需任何外部服务器，保障数据安全" FontSize="12" Foreground="#888"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
